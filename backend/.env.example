# Leave OPENAI_API_KEY empty to run deterministic demo mode.
# Set it to enable OpenAI-powered panel generation and interventions.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
AGORA_ENV=development

# Comma-separated production frontend origins, e.g.
# AGORA_CORS_ORIGINS=https://agora-ai.vercel.app
AGORA_CORS_ORIGINS=

# Defaults to localhost/LAN development origins when unset.
AGORA_CORS_ORIGIN_REGEX=
